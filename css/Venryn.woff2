<script><!--
$('#select-city a').on('click', function() {
	
	var city_id = $(this).data('city_id');
	$.ajax({
		type: 'post',
		url:  'index.php?route=common/city/change&city_id=' + city_id,
		dataType: 'json',
		cache: false,
		success: function(json) {
			$('#current_city_name').text(json['current_city']['name']);
			$('#select-city .modal-title').text('Выбран город: ' + json['current_city']['name']);
			$('#select-city .modal-body a').removeClass('bold');
			$('#select-city .modal-body a[data-city_id=' + json['current_city']['city_id'] + ']').addClass('bold');
			$('#select-city .close').trigger('click');
		}
	});	
});	
	
	
--></script></div>
