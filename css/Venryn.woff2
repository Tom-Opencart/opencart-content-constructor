<script type="text/javascript">
	function sendDataForEcommerceYandexMetrica(options) {
				let id = options.id; // required
		let event = options.event; // required
		let id_type = (typeof(options.id_type) != 'undefined' ? options.id_type : 'product_id');
		let quantity = (typeof(options.quantity) != 'undefined' ? options.quantity : 'null');
		let async = (typeof(options.async) != 'undefined' ? options.async : true);

		$.ajax({
			url: 'index.php?route=product/product/getProductDataForYandexMetrica',
			async: (typeof(async) != 'undefined' ? async : true),
			type: 'post',
			data: 'id=' + id + '&event=' + event + '&id_type=' + id_type + '&quantity=' + quantity,
			dataType: 'json',
			success: function(json) {
				if (event == 'add') {
					dataLayer.push({"ecommerce": {"currencyCode": json['currency_code'], "add": {"products": [json['product']]}}});
				} else if (event == 'remove') {
					dataLayer.push({"ecommerce": {"currencyCode": json['currency_code'], "remove": {"products": [json['product']]}}});
				}
			},
			error: function(xhr, ajaxOptions, thrownError) {
				alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
			}
		});
			}


</script>

<script>
	function initSideTooltip() {
		$('.side-tooltip-item').on('mouseenter', function () {
			if (window.innerWidth <= 991) return; // Отключаем ховер на мобильных

			var $element = $(this);
			var $tooltipData = $element.next();
			var elementWidth = $element.outerWidth();
			var maxWidth = 50;

			if ($element.parent().hasClass('sticker')) {
				if ($(window).width() > 991) {
					maxWidth = $element.closest('.product-thumb').width() - elementWidth;
				}
				$('.stickers-left, .stickers-right').css({ zIndex: 5 });
				$element.parent().parent().css({ zIndex: 7 });
			}

			$tooltipData.css({ maxWidth: maxWidth }).fadeIn(200);
		});

		$('.side-tooltip-item').on('mouseleave', function () {
			if (window.innerWidth <= 991) return; // Отключаем ховер на мобильных

			var $tooltipData = $(this).next();
			if (!$tooltipData.is(':hover')) {
				$tooltipData.fadeOut(200);
			}
		});

		$('.side-tooltip').on('mouseenter', function () {
			if (window.innerWidth <= 991) return; // Отключаем на мобильных
			$(this).stop(true, true).fadeIn(200);
		});

		$('.side-tooltip').on('mouseleave', function () {
			if (window.innerWidth <= 991) return;
			$(this).fadeOut(200);
		});

		// Обработка кликов на мобильных устройствах
		$('.side-tooltip-item').on('click', function (e) {
			if (window.innerWidth > 991) return; // Отключаем на десктопе

			e.preventDefault();

			if ($(this).parent().hasClass('sticker')) {
				$('.stickers-left, .stickers-right').css({ zIndex: 5 });
				$(this).parent().parent().css({ zIndex: 7 });
			}

			var $tooltipData = $(this).next();
			if ($tooltipData.is(':visible')) {
				$tooltipData.fadeOut(200);
			} else {
				$('.side-tooltip').fadeOut(200); // Закрываем другие подсказки
				$tooltipData.fadeIn(200);
			}
		});

		// Закрытие подсказки при клике вне неё
		$(document).on('click touchstart', function (e) {
			if (!$(e.target).closest('.side-tooltip-item, .side-tooltip').length) {
				$('.side-tooltip').fadeOut(200);
			}
		});
	}


	$(document).ready(function () {
		  initSideTooltip();
	  });
</script>



