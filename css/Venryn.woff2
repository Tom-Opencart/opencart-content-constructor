	<script>
	$('#cookie-settings-btn').click(function() {
	  $('#bottom-cookie .cookie-set').slideToggle();
	  
	  if (!$(this).data('opened')) {
		$('#bottom-cookie input[value="allow_analytics"], #bottom-cookie input[value="allow_marketing"]').prop('checked', false);
		$(this).data('opened', true);
	  }
	});
	</script>
