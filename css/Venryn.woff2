<script><!--

  if (document.cookie.match(/(?:^|; )bottom-cookie=([^;]*)/) !== null) {
	  document.getElementById('bottom-cookie').remove();
  } 
  
  var bottomCookie = document.getElementById('bottom-cookie');
  if (bottomCookie) {
	document.getElementById('bottom-cookie-close').addEventListener('click', function(){
	  	  
	  var checkedInputs = document.querySelectorAll('#bottom-cookie .cookie-set input:checked');
	  console.log(checkedInputs);
	  for (var i = 0; i < checkedInputs.length; i++) {
		  var cookieName = checkedInputs[i].value;
		  var date = new Date();
		  date.setTime(date.getTime() + (7 * 24 * 60 * 60 * 1000));
		  document.cookie = cookieName + "=" + cookieName + "; expires=" + date.toUTCString() + "; path=/";
		  console.log(cookieName);
	  }
	  
	  var date = new Date();
	  date.setTime(date.getTime() + (7 * 24 * 60 * 60 * 1000));
	  document.cookie = "bottom-cookie=close; expires=" + date.toUTCString() + "; path=/";
	  
	  bottomCookie.remove();
	});
  }
    //--></script>
