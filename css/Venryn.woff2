<div id="menu-mobile-box"></div>
<script>
	$(document).on("ready", function() {		
		resizeMenu();
		setTimeout(function() {
			resizeMenu();
			$('.navbar').css('overflow', 'visible');
		}, 1000);
	});

	function resizeMenu() {
		$("#nav li.more").before($("#overflow > li"));
		var e = $("#nav > li.more"),
			t = $("#nav > li:not(.more)"),
			s = e.width() + 60,
			o = $("#nav").parent().width();
		for (t.each(function() {
				s += $(this).width()
			}),
			o < s ? e.show() : e.hide(); o < s;)
			s -= t.last().width(),
			t.last().prependTo("#overflow"),
			t.splice(-1, 1);
		$("#overflow").width();
		$('.menu-items').css('opacity', '1');
	}
	function initMenu() {
		
		$(document).off('click.menuEvents');
		$('#menu').off('click.menuEvents mouseenter.menuEvents');
		
		// Мобильное меню
		$(document)
			.on('click.menuEvents', '#menu-mobile-box .menu-toggle', function() {
				$(this).parent().next().addClass('opened');
			})
			.on('click.menuEvents', '#menu-mobile-box .menu-back', function() {
				$(this).parent().parent().removeClass('opened');
			})
			.on('click.menuEvents', '#menu_mobile_button_service', function() {
				$(this).toggleClass('active');
				$('#menu-mobile-box .menu-categories').removeClass('show');
				$('#menu-mobile-box .opened').removeClass('opened');
				$('#menu_mobile_button_catalog').removeClass('active');
				$('#menu-mobile-box .menu-services').toggleClass('show');
				$('body').toggleClass('no-scroll', $('#menu-mobile-box .menu-services').hasClass('show'));
			})
			.on('click.menuEvents', '#menu_mobile_button_catalog', function() {
				$(this).toggleClass('active');
				$('#menu-mobile-box .menu-services').removeClass('show');
				$('#menu-mobile-box .opened').removeClass('opened');
				$('#menu_mobile_button_service').removeClass('active');
				$('#menu-mobile-box .menu-categories').toggleClass('show');
				$('body').toggleClass('no-scroll', $('#menu-mobile-box .menu-categories').hasClass('show'));
			})
			.on('click.menuEvents', '#menu_mobile_button', function() {
				$(this).toggleClass('opened');
				$('#mobile-menu').toggleClass('show');
				$('body').toggleClass('no-scroll');
				if ($('#mobile-menu').hasClass('show')) {
					$('#top-promo').hide();
				}
			});
		
		// Десктопное меню 
		$('#menu')
			.on('click.menuEvents', '.catalog-button', function() {
				$('#menu .inner-menu.services-menu').removeClass('open');
				$('#menu .service-button').removeClass('opened');
				$('#menu .inner-menu.products-menu').toggleClass('open');
				$(this).toggleClass('opened');
			})
			.on('mouseenter.menuEvents', '.inner-menu.products-menu li.hover', function() {
				var root_id = $(this).data('id');
				$('#menu .inner-menu.products-menu .hover').removeClass('opened');
				$('#menu .inner-menu.products-menu .hover-menu').removeClass('active');
				$(this).addClass('opened');
				$("#menu .inner-menu.products-menu .hover-menu[data-id='" + root_id + "']").addClass("active");
			})
			.on('click.menuEvents', '.products-menu .menu-img-close', function() {
				$('#menu .inner-menu.products-menu').removeClass('open');
				$('#menu .catalog-button').removeClass('opened');
			})
			.on('click.menuEvents', '.service-button', function() {
				$('#menu .inner-menu.products-menu').removeClass('open');
				$('#menu .catalog-button').removeClass('opened');
				$('#menu .inner-menu.services-menu').toggleClass('open');
				$(this).toggleClass('opened');
			})
			.on('mouseenter.menuEvents', '.inner-menu.services-menu li.hover', function() {
				var root_id = $(this).data('id');
				$('#menu .inner-menu.services-menu .hover').removeClass('opened');
				$('#menu .inner-menu.services-menu .hover-menu').removeClass('active');
				$(this).addClass('opened');
				$("#menu .inner-menu.services-menu .hover-menu[data-id='" + root_id + "']").addClass("active");
			})
			.on('click.menuEvents', '.services-menu .menu-img-close', function() {
				$('#menu .inner-menu.services-menu').removeClass('open');
				$('#menu .inner-menu.products-menu').removeClass('open');
				$('#menu .catalog-button').removeClass('opened');
			});
		
	}
	
	$(document).ready(function() {
		$('#menu-mobile-box').load('index.php?route=common/menu/mobile&layout_id=4', function() {
			mobile();
		});
					initMenu();
			});
</script>



